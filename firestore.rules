// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (uid)
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string (optional)
//   - walletBalance: number (required, >= 0)
//   - role: string (required, enum: ['admin', 'user'])
//   - createdAt: timestamp (required)
//
// Collection: gift_cards
// Document ID: cardId
// Fields:
//   - name: string (required)
//   - description: string (optional)
//   - price: number (required, > 0)
//   - imageUrl: string (optional)
//   - category: string (optional)
//   - stock: number (required, >= 0)
//
// Collection: gift_card_codes
// Document ID: codeId
// Fields:
//   - giftCardId: string (required)
//   - code: string (required)
//   - isSold: bool (required)
//   - soldTo: string (optional, userId)
//   - soldAt: timestamp (optional)
//
// Collection: transactions
// Document ID: transactionId
// Fields:
//   - userId: string (required)
//   - type: string (required, enum: ['funding', 'purchase'])
//   - amount: number (required)
//   - status: string (required, enum: ['pending', 'success', 'failed'])
//   - metadata: map (optional)
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "aduragb640@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'walletBalance', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.walletBalance is number && data.walletBalance >= 0 &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    function isValidGiftCard(data) {
      return data.keys().hasAll(['name', 'price', 'stock']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price > 0 &&
             data.stock is number && data.stock >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Only system (admin) or user on creation (with default balance 0)
      allow create: if isAuthenticated() && isOwner(userId) && 
                      request.resource.data.walletBalance == 0 &&
                      request.resource.data.role == 'user';
      allow update: if isAdmin(); // Users cannot update their own balance or role
    }

    match /gift_cards/{cardId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    match /gift_card_codes/{codeId} {
      // Only admin can see all codes. Users can see codes they bought (via query or specific ID)
      allow read: if isAdmin() || (isAuthenticated() && resource.data.soldTo == request.auth.uid);
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if false; // Only server-side creation
      allow update: if false;
      allow delete: if false;
    }
  }
}
